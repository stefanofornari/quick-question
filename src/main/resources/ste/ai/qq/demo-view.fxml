<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import ste.ai.qq.WebChatView?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ste.ai.qq.demo.DemoViewController">
    <left>
      <VBox BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <children>
              <HBox spacing="10.0">
                  <children>
                      <VBox spacing="5.0">
                          <children>
                              <HBox alignment="CENTER_LEFT">
                                  <children>
                                      <Label prefWidth="50.0" text="Name" />
                                      <TextField fx:id="nameField" prefWidth="200.0" promptText="Gemini" />
                                  </children>
                              </HBox>
                              <HBox alignment="CENTER_LEFT">
                                  <children>
                                      <Label prefWidth="50.0" text="URL" />
                                      <TextField fx:id="urlField" prefWidth="200.0" promptText="https://gemini.google.com" />
                                  </children>
                              </HBox>
                          </children>
                      </VBox>
                      <Button fx:id="addButton" onAction="#handleAddEntry" text="Add" />
                  </children>
                  <padding>
                      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                  </padding>
              </HBox>
                <TableView fx:id="entriesTable" prefWidth="320.0">
                    <columns>
                        <TableColumn fx:id="nameColumn" prefWidth="120.0" text="Name" />
                        <TableColumn fx:id="urlColumn" prefWidth="200.0" text="URL" />
                    </columns>
                </TableView>
         </children>
      </VBox>
    </left>
    <center>
        <WebChatView fx:id="webChatView" />
    </center>
</BorderPane>
